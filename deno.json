{
  "name": "@steno/steno",
  "version": "0.3.0",
  "description": "A fast Deno-powered static site generator.",
  "exports": "./mod.ts",
  "license": "MIT",
  "publish": {
    "exclude": [
      ".github",
      "docs",
      "test",
      "test.ts",
      "**/*_test.ts",
      "packages",
      "benchmarks"
    ]
  },
  "tasks": {
    "dev": "deno task --cwd test dev",
    "test": "deno test -A ./test.ts",
    "bench": "deno bench -A ./benchmarks",
    "bench:check": "deno run -A ./benchmarks/perf_budget.ts",
    "bench:trends": "deno run -A ./benchmarks/bench_trends.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@std/path": "jsr:@std/path@1.1.6",
    "@std/toml": "jsr:@std/toml@1.0.11",
    "@std/yaml": "jsr:@std/yaml@1.1.2",
    "marked": "npm:marked@latest"
  }
}
