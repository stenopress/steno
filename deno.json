{
  "name": "@steno/steno",
  "version": "0.2.0",
  "description": "A fast Deno-powered static site generator.",
  "exports": "./mod.ts",
  "license": "MIT",
  "publish": {
    "exclude": [
      ".github",
      "docs",
      "test",
      "test.ts",
      "**/*_test.ts",
      "packages"
    ]
  },
  "tasks": {
    "dev": "deno task --cwd test dev",
    "test": "deno test -A ./test.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/path": "jsr:@std/path@1",
    "@std/toml": "jsr:@std/toml@1.0.11",
    "@std/yaml": "jsr:@std/yaml@1",
    "marked": "npm:marked@latest"
  }
}
