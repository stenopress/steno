{
  "name": "@steno/steno",
  "version": "0.7.0",
  "description": "An ultra-lightweight static site generator powered by the Steno Hybrid Runtime.",
  "exports": "./mod.ts",
  "license": "MIT",
  "fmt": {
    "exclude": ["test/content", "test/test-theme"]
  },
  "publish": {
    "exclude": [
      ".github",
      "AGENTS.md",
      "crates",
      "docs",
      "scripts",
      "test",
      "test.ts",
      "**/*_test.ts",
      "packages",
      "benchmarks"
    ]
  },
  "tasks": {
    "setup": "deno task build:core && deno cache mod.ts test/mod.ts",
    "doctor": "deno run -A ./mod.ts doctor",
    "dev": "deno task build:core && deno task --cwd test dev",
    "dev:portable": "deno task --cwd test dev:portable",
    "test": "deno test -A ./test.ts",
    "test:native": "deno task build:core && deno run -A ./scripts/test_engine.ts native",
    "test:portable": "deno run -A ./scripts/test_engine.ts portable",
    "check": "deno fmt --check && deno lint && deno check mod.ts",
    "build:core": "cd crates/steno_core && cargo build --release",
    "bench": "deno task build:core && deno bench -A",
    "bench:check": "deno run -A ./benchmarks/perf_budget.ts",
    "bench:trends": "deno run -A ./benchmarks/bench_trends.ts",
    "release:check": "deno run -A ./scripts/verify_native_bundle.ts && deno publish --dry-run --allow-dirty"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@std/path": "jsr:@std/path@1.1.6",
    "@std/toml": "jsr:@std/toml@1.0.11",
    "@std/yaml": "jsr:@std/yaml@1.1.2",
    "@std/fs": "jsr:@std/fs@1.0.2",
    "marked": "npm:marked@latest"
  }
}
